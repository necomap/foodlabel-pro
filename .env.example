# ============================================================
# FoodLabel Pro - 環境変数設定
# このファイルを .env.local としてコピーして値を設定してください
# .env.local は .gitignore に含まれています（コミットしないこと）
# ============================================================

# ----- データベース -----
# PostgreSQL接続文字列
# Vercel Postgresの場合: Settings > Storage > Connect から取得
# ローカルの場合: postgresql://USER:PASSWORD@localhost:5432/foodlabel_pro
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/foodlabel_pro"

# ----- NextAuth.js -----
# ランダムな秘密鍵 (openssl rand -base64 32 で生成)
NEXTAUTH_SECRET="your-secret-key-here"
# 本番URLまたは開発URL
NEXTAUTH_URL="http://localhost:3000"

# ----- メール送信（認証メール・パスワードリセット） -----
# GmailのSMTP例（Gmailの場合はアプリパスワードを使用）
EMAIL_SERVER_HOST="smtp.gmail.com"
EMAIL_SERVER_PORT="587"
EMAIL_SERVER_USER="your-email@gmail.com"
EMAIL_SERVER_PASSWORD="your-app-password"
EMAIL_FROM="FoodLabel Pro <your-email@gmail.com>"

# ----- Stripe（課金機能）-----
# Stripeダッシュボード > Developers > API keys から取得
STRIPE_PUBLIC_KEY="pk_test_..."
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
# プレミアムプランの価格ID（Stripeで作成）
STRIPE_PREMIUM_PRICE_ID="price_..."

# ----- アプリ設定 -----
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_NAME="FoodLabel Pro"

# ----- 管理者 -----
# 管理者として初期設定するメールアドレス
ADMIN_EMAIL="admin@your-domain.com"
